# ── Company-Profile (Peken Banyumasan marketing site) — example values ──
# Copy to `.env` and fill in real values. Do NOT commit `.env`.
#
# Company-Profile is the public marketing surface; it has no API of its
# own. These env vars only point to sibling Peken apps for cross-app
# navigation (e.g., the Login modal jumps to /login on the right app).
# All URLs are origin-only; specific paths (e.g., /login) are appended
# explicitly in JSX.
#
# Only the two public-facing roles (Kolaborator, Artisan) are exposed.
# Gate is an internal admin dashboard and is intentionally NOT linked
# from the marketing site.

VITE_KOLABORATOR_URL=http://localhost:5175
VITE_ARTISAN_URL=http://localhost:5174

# Backend API base URL used by src/services/api.js for dynamic content
# (programs, karya, profiles, gallery). Leave empty to use same-origin
# (e.g. Vite's `proxy` config). Do NOT add a trailing slash.
VITE_API_URL=
