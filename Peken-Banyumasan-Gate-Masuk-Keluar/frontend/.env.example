# ── Gate (Admin & Petugas Panel) — example values for local development ──
# Copy to `.env` and fill in real values. Do NOT commit `.env`.

# HTTP API base — origin only, NO trailing /api.
# Endpoint paths in src/services/endpoints.js already include the /api/ prefix.
# Local backend (docker-compose): http://localhost:8002
# Production HuggingFace Space  : https://<username>-peken-gate-api.hf.space
VITE_API_URL=http://localhost:8002

# Supabase — digunakan untuk Auth (login/logout/session) DAN Realtime
# (kunjungan subscription). Gunakan anon key, BUKAN service_role key.
# Isi dari Supabase Dashboard → Project Settings → API.
# Biarkan kosong jika belum ada Supabase project (fallback: polling + no auth).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Cross-app navigation. Public artisan/event profile pages live in the
# Artisan app (UMKM frontend); the Profile.jsx and AdminLayout.jsx links
# redirect there.
VITE_ARTISAN_URL=http://localhost:5176

# Public Company-Profile origin. Used by Kelola CP so admin previews of
# legacy seed images (/assets/...) resolve against the CP site instead of
# Gate's own origin. The "Lihat Company Profile" top-bar button uses the
# same value. Production env already sets this in .env.production.
VITE_COMPANY_URL=http://localhost:5175

# ── Demo / Dummy Mode ──
# true  → login dengan email/password apapun, semua data dari dummy lokal.
# false → koneksi real ke VITE_API_URL (butuh backend aktif).
VITE_DUMMY_MODE=false
