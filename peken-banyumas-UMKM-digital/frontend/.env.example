# Copy file ini menjadi .env dan isi nilainya
# Salin file ini: cp .env.example .env

# URL backend artisan (default lokal)
VITE_API_URL=http://localhost:8004

# URL Company Profile (Beranda Publik)
VITE_COMPANY_URL=http://localhost:5174

# Supabase project — ambil dari Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
