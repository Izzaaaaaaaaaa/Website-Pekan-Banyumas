# ── Peken Banyumas — Artisan Backend ─────────────────────────────────────────
# Salin file ini: cp .env.example .env
# Jangan commit file .env ke repository.

# ── Supabase Database (pooler URL) ───────────────────────────────────────────
# Ambil dari: Supabase Dashboard → Project Settings → Database → Connection string
# Gunakan "Transaction pooler" (port 6543) untuk serverless / short-lived connections.
SUPABASE_DB_URL=postgresql+asyncpg://postgres.<project-ref>:<db-password>@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ── Supabase REST & Auth ──────────────────────────────────────────────────────
# Ambil dari: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<copy from team .env>

# ── Supabase JWT Secret ───────────────────────────────────────────────────────
# Ambil dari: Supabase Dashboard → Project Settings → API → JWT Settings → JWT Secret
# Digunakan untuk memverifikasi token dari FE tanpa hit Supabase network.
SUPABASE_JWT_SECRET=<copy from team .env>
