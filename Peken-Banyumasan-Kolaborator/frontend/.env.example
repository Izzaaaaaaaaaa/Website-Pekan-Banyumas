# ── Kolaborator (Pekerja Kreatif Dashboard) — example values for local dev ──
# Copy to `.env` and fill in real values. Do NOT commit `.env`.

# HTTP API base — origin only, NO trailing /api.
# Endpoint paths in src/services/endpoints.js already include the /api/ prefix.
VITE_API_URL=http://localhost:5000

# Cross-app navigation — points to the Company-Profile marketing site
# ("Beranda" back-link from Login/Register, footer link from Profil page).
VITE_COMPANY_URL=http://localhost:5174

# ── Demo / Dummy Mode ──
# true  → login dengan email/password apapun, semua data dari dummy lokal.
# false → koneksi real ke VITE_API_URL (butuh backend aktif).
VITE_DUMMY_MODE=false
