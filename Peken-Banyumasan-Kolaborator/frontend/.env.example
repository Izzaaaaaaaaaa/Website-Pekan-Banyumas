# ── Kolaborator (Pekerja Kreatif Dashboard) — example values for local dev ──
# Copy to `.env` and fill in real values. Do NOT commit `.env`.

# HTTP API base — origin only, NO trailing /api.
# Endpoint paths in src/services/endpoints.js already include the /api/ prefix.
# NOTE: Kolaborator has its OWN dedicated backend — must NOT share the same
# VITE_API_URL as the UMKM/Artisan app. Each of the three dashboards
# (Gate, UMKM, Kolaborator) talks to a separate serverside deployment
# that all share one database.
# Local backend (docker-compose): http://localhost:8003
# Production HuggingFace Space  : https://<username>-peken-kolaborator-api.hf.space
VITE_API_URL=http://localhost:8003

# Supabase — Auth (login/session/auto-refresh). Gunakan anon key, BUKAN service_role key.
# Isi dari Supabase Dashboard → Project Settings → API.
# Biarkan kosong di .env.example; nilai asli diisi di .env atau Vercel env vars.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Cross-app navigation — points to the Company-Profile marketing site
# ("Beranda" back-link from Login/Register, footer link from Profil page).
VITE_COMPANY_URL=http://localhost:5173

# ── Demo / Dummy Mode ──
# true  → login dengan email/password apapun, semua data dari dummy lokal.
# false → koneksi real ke VITE_API_URL (butuh backend aktif).
VITE_DUMMY_MODE=false
